# GEMINI_API_KEY: Primary Gemini API key.
# GEMINI_API_KEYS: Optional comma-separated backup keys used when the primary key
# hits quota or becomes invalid.
# You can also use numbered variables such as GEMINI_API_KEY_2, GEMINI_API_KEY_3,
# and they will be merged automatically at build time.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
GEMINI_API_KEYS="MY_BACKUP_GEMINI_API_KEY_1,MY_BACKUP_GEMINI_API_KEY_2"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
